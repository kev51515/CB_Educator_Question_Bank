  "devDependencies": {
    "@axe-core/playwright": "4.11.3",
    "@eslint/js": "^10.0.1",
    "@types/dompurify": "^3.0.5",
    "@playwright/test": "1.60.0",
    "@types/katex": "^0.16.7",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "postcss": "^8.5.15",
