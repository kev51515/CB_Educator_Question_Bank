  "stem": "<p>One pound of cherries costs $5. At this rate, how many dollars will <math><mi>p</mi></math> pounds of cherries cost?</p>",
  "answerOptions": [
    {"id": "a", "content": "<p><math><mn>5</mn><mo>+</mo><mi>p</mi></math></p>"},
