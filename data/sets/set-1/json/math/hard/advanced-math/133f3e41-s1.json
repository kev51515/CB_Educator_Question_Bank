      "content": "<p><i>a</i><i>c</i><i>d</i>/(<i>a</i><i>c</i> + <i>a</i><i>d</i> + <i>c</i><i>d</i>)</p>"
    },
    {
      "id": "c",
      "content": "<p>(<i>a</i> + <i>c</i> + <i>d</i>)/(<i>a</i><i>c</i><i>d</i>)</p>"
    },
    {
      "id": "d",
      "content": "<p><i>a</i><i>c</i><i>d</i></p>"
    }
