  "stem": "<p>For positive values of p and q, which of the following is equivalent to &radic;((p &minus; q)<sup>5</sup>) &middot; &radic;(p &minus; q)?</p>",
  "answerOptions": [
    {
      "id": "a",
      "content": "<p>(p &minus; q)<sup>2</sup></p>"
    },
    {
      "id": "b",
      "content": "<p>p<sup>3</sup> &minus; q<sup>3</sup></p>"
    },
    {
      "id": "c",
      "content": "<p>p<sup>2</sup> q<sup>2</sup></p>"
    },
    {
      "id": "d",
      "content": "<p>p<sup>3</sup> &minus; 3p<sup>2</sup>q + 3pq<sup>2</sup> &minus; q<sup>3</sup></p>"
    }
  ],
  "keys": [
    "d"
