  "stem": "<p>In the <em>xy</em>-plane, the points (1, 8) and (5, \u22124) lie on the graph of which of the following linear functions?</p>",
  "answerOptions": [
    {
      "id": "a",
      "content": "<p><em>f</em>(<em>x</em>) = (1/3)<em>x</em> + 8</p>"
    },
    {
      "id": "b",
      "content": "<p><em>f</em>(<em>x</em>) = 3<em>x</em> + 5</p>"
    },
    {
      "id": "c",
      "content": "<p><em>f</em>(<em>x</em>) = \u22122<em>x</em> + 10</p>"
    },
    {
      "id": "d",
      "content": "<p><em>f</em>(<em>x</em>) = \u22123<em>x</em> + 11</p>"
    }
  ],
