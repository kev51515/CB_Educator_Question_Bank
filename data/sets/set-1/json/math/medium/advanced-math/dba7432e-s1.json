    {
      "id": "c",
      "content": "<p><em>g</em>(<em>x</em>) = 3(2<sup><em>x</em>+1</sup>)</p>"
    },
    {
      "id": "d",
      "content": "<p><em>g</em>(<em>x</em>) = 6(2<sup><em>x</em></sup>)</p>"
