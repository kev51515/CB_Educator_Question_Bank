  "type": "spr",
  "stem": "<p style=\"text-align: left;\">How many <span style=\"text-decoration: underline;\">tablespoons</span> are equivalent to <math alttext=\"14\"><mn>14</mn>\n</math> teaspoons? <math alttext=\"left parenthesis 3 teaspoons  equals 1 tablespoon right parenthesis\"><mfenced><mrow><mn>3</mn><mo>&#160;</mo><mtext>teaspoons</mtext><mo>=</mo><mn>1</mn><mo>&#160;</mo><mtext>tablespoon</mtext></mrow></mfenced></math></p>",
  "answerOptions": null,
