    {
      "id": "a",
      "content": "<p class=\"choice_paragraph \"><span class=\"math_expression \"><span class=\"math-container\"><img align=\"middle\" role=\"math\" class=\"math-img\" src=\"data:image/png;base64,\" alt=\"one fifth\"></span></span></p>\n"
