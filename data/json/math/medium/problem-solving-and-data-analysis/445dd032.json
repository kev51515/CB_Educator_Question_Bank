    {
      "id": "a",
      "content": "<p class=\"choice_paragraph \"><span class=\"math_expression \"><span class=\"math-container\"><img align=\"middle\" role=\"math\" class=\"math-img\" src=\"data:image/png;base64,\" alt=\"3 times, open parenthesis, 13 point 5 0 z, close parenthesis \"></span></span></p>\n"
    },
    {
      "id": "b",
      "content": "<p class=\"choice_paragraph \"><span class=\"math_expression \"><span class=\"math-container\"><img align=\"middle\" role=\"math\" class=\"math-img\" src=\"data:image/png;base64,\" alt=\"3 plus 13 point 5 0 z\"></span></span></p>\n"
    },
    {
      "id": "c",
      "content": "<p class=\"choice_paragraph \"><span class=\"math_expression \"><span class=\"math-container\"><img align=\"middle\" role=\"math\" class=\"math-img\" src=\"data:image/png;base64,\" alt=\"3 z plus 13 point 5 0 z\"></span></span></p>\n"
