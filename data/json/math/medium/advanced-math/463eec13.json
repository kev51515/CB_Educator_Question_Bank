  "type": "mcq",
  "stem": "<p class=\"stem_paragraph \">If <span class=\"math_expression \"><span class=\"math-container\"><img align=\"middle\" role=\"math\" class=\"math-img\" src=\"data:image/png;base64,\" alt=\"x is not equal to 0\"></span></span>, which of the following expressions is equivalent to <span class=\"math_expression \"><span class=\"math-container\"><img align=\"middle\" role=\"math\" class=\"math-img\" src=\"data:image/png;base64,\" alt=\"the fraction with numerator the square root of 16 x to the fourth power, y to the eighth power, end root, and denominator x cubed, end fraction\"></span></span> ?</p>\n",
  "answerOptions": [
    {
      "id": "a",
      "content": "<p class=\"choice_paragraph \"><span class=\"math_expression \"><span class=\"math-container\"><img align=\"middle\" role=\"math\" class=\"math-img\" src=\"data:image/png;base64,\" alt=\"8 x squared, y to the fourth power\"></span></span></p>\n"
    },
    {
      "id": "b",
      "content": "<p class=\"choice_paragraph \"><span class=\"math_expression \"><span class=\"math-container\"><img align=\"middle\" role=\"math\" class=\"math-img\" src=\"data:image/png;base64,\" alt=\"4 x, y to the fourth power\"></span></span></p>\n"
    },
    {
      "id": "c",
      "content": "<p class=\"choice_paragraph \"><span class=\"math_expression \"><span class=\"math-container\"><img align=\"middle\" role=\"math\" class=\"math-img\" src=\"data:image/png;base64,\" alt=\"4 x raised to the negative 2 power, y squared\"></span></span></p>\n"
    },
    {
      "id": "d",
      "content": "<p class=\"choice_paragraph \"><span class=\"math_expression \"><span class=\"math-container\"><img align=\"middle\" role=\"math\" class=\"math-img\" src=\"data:image/png;base64,\" alt=\"4 x raised to the negative 1 power, y to the fourth power\"></span></span></p>\n"
