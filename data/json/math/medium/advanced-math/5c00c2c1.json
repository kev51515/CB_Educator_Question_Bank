    {
      "id": "a",
      "content": "<p class=\"choice_paragraph \"><span class=\"math_expression \"><span class=\"math-container\"><img align=\"middle\" role=\"math\" class=\"math-img\" src=\"data:image/png;base64,\" alt=\"p of t equals, 1 point 1 6 2 times, 24 raised to the t power\"></span></span></p>\n"
