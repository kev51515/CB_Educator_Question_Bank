  "stem": "<p class=\"stem_paragraph \">If&nbsp;(<span class=\"italic\">x</span>, <span class=\"italic\">y</span>) is a solution of the system of equations above and <span class=\"italic\">x</span> &gt; 0, what is the value of&nbsp;<span class=\"italic\">xy</span> ?</p>\n",
  "answerOptions": [
    {
      "id": "a",
      "content": "<p>1</p>\n"
