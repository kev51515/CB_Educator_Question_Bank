  "type": "mcq",
  "stem": "<p class=\"stem_paragraph \">Which of the following could define the relationship between <span class=\"italic\"><span class=\"formatted_text font_style:italic \">s</span></span> and <span class=\"italic\"><span class=\"formatted_text font_style:italic \">P</span></span> ?</p>\n",
  "answerOptions": [
    {
      "id": "a",
      "content": "<p class=\"choice_paragraph \"><span class=\"math_expression \"><span class=\"math-container\"><img align=\"middle\" role=\"math\" class=\"math-img\" src=\"data:image/png;base64,\" alt=\"P equals, 3 s plus 10\"></span></span></p>\n"
    },
    {
      "id": "b",
      "content": "<p class=\"choice_paragraph \"><span class=\"math_expression \"><span class=\"math-container\"><img align=\"middle\" role=\"math\" class=\"math-img\" src=\"data:image/png;base64,\" alt=\"P equals, ten thirds s, plus 8\"></span></span></p>\n"
    },
    {
      "id": "c",
      "content": "<p class=\"choice_paragraph \"><span class=\"math_expression \"><span class=\"math-container\"><img align=\"middle\" role=\"math\" class=\"math-img\" src=\"data:image/png;base64,\" alt=\"P equals, ten thirds s, minus 2\"></span></span></p>\n"
    },
    {
      "id": "d",
      "content": "<p class=\"choice_paragraph \"><span class=\"math_expression \"><span class=\"math-container\"><img align=\"middle\" role=\"math\" class=\"math-img\" src=\"data:image/png;base64,\" alt=\"P equals, three tenths s, minus one tenth\"></span></span></p>\n"
