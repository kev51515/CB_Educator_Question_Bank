    {
      "id": "b",
      "content": "<p class=\"choice_paragraph \"><span class=\"math_expression \"><span class=\"math-container\"><img align=\"middle\" role=\"math\" class=\"math-img\" src=\"data:image/png;base64,\" alt=\"g plus t, equals, 1 point 5 0 plus 12 point 5 0\"></span></span></p>\n"
