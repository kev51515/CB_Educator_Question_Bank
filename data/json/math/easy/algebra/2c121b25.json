      "id": "d",
      "content": "<span class=\"math_expression \">\n            <span class=\"math-container\"><img align=\"middle\" role=\"math\" class=\"math-img\" src=\"data:image/png;base64,\" alt=\"30 x, plus, 70 y, is greater than or equal to, 400\"></span></span>\n"
