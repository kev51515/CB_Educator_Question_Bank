      "content": "<p class=\"choice_paragraph block_choice\"><span class=\"math_expression \"><span class=\"math-container\"><img align=\"middle\" role=\"math\" class=\"math-img\" src=\"data:image/png;base64,\" alt=\"y equals, 6 x plus 8\"></span></span></p>\n"
