      "content": "<p class=\"choice_paragraph block_choice\"><span class=\"math_expression \"><span class=\"math-container\"><img align=\"middle\" role=\"math\" class=\"math-img\" src=\"data:image/png;base64,\" alt=\"y equals, 8 x plus 6\"></span></span></p>\n"
