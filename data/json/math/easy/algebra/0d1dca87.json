  "stem": "<p class=\"stem_paragraph \">If <span class=\"math_expression \"><span class=\"math-container\"><img align=\"middle\" role=\"math\" class=\"math-img\" src=\"data:image/png;base64,\" alt=\"the ordered pair x comma y \"></span></span> is the solution to the given system of equations, what is the value of <span class=\"italic\">y</span> ?</p>\n",
  "answerOptions": [],
