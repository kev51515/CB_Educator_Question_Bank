  "stem": "<p class=\"stem_paragraph \">Lani spent 15% of her 8-hour workday in meetings. How many <u><span class=\"underline\"><span class=\"underline \">minutes</span></span></u> of her workday did she spend in meetings?</p>\n",
  "answerOptions": [
    {
      "id": "a",
      "content": "<p class=\"choice_paragraph \"><span class=\"align align-16\">1</span>.2</p>\n"
    },
    {
