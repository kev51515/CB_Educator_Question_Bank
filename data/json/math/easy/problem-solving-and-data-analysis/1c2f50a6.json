  "type": "mcq",
  "stem": "<p class=\"stem_paragraph \">During a sale, the original prices of all the items in a clothing store have been reduced by 20%. What is the sale price of a jacket with an original price of $50&nbsp;?</p>\n",
  "answerOptions": [
    {
      "id": "a",
      "content": "<p class=\"choice_paragraph \">$12</p>\n"
    },
