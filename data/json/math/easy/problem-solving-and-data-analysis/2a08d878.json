      "content": "<p class=\"choice_paragraph \"><span class=\"math_expression \"><span class=\"math-container\"><img align=\"middle\" role=\"math\" class=\"math-img\" src=\"data:image/png;base64,\" alt=\"the fraction n over 12\"></span></span></p>\n"
    },
    {
      "id": "b",
      "content": "<p class=\"choice_paragraph \"><span class=\"math_expression \"><span class=\"math-container\"><img align=\"middle\" role=\"math\" class=\"math-img\" src=\"data:image/png;base64,\" alt=\"the fraction n over n plus 12, end fraction\"></span></span></p>\n"
    },
    {
      "id": "c",
      "content": "<p class=\"choice_paragraph \"><span class=\"math_expression \"><span class=\"math-container\"><img align=\"middle\" role=\"math\" class=\"math-img\" src=\"data:image/png;base64,\" alt=\"the fraction 12 over n\"></span></span></p>\n"
