  "stem": "<p class=\"stem_paragraph \">Which of the following is equivalent to <span class=\"math_expression \"><span class=\"math-container\"><img align=\"middle\" role=\"math\" class=\"math-img\" src=\"data:image/png;base64,\" alt=\"2 times, open parenthesis, x squared minus x, close parenthesis, plus 3 times, open parenthesis, x squared minus x, close parenthesis\"></span></span> ?</p>\n",
  "answerOptions": [
    {
      "id": "a",
      "content": "<p class=\"choice_paragraph \"><span class=\"math_expression \"><span class=\"math-container\"><img align=\"middle\" role=\"math\" class=\"math-img\" src=\"data:image/png;base64,\" alt=\"5 x squared, minus 5 x\"></span></span></p>\n"
    },
    {
      "id": "b",
      "content": "<p class=\"choice_paragraph \"><span class=\"math_expression \"><span class=\"math-container\"><img align=\"middle\" role=\"math\" class=\"math-img\" src=\"data:image/png;base64,\" alt=\"5 x squared, plus 5 x\"></span></span></p>\n"
