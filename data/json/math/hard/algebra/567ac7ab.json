    {
      "id": "c",
      "content": "<p class=\"choice_paragraph block_choice\"><span class=\"math_expression \"><span class=\"math-container\"><img align=\"middle\" role=\"math\" class=\"math-img\" src=\"data:image/png;base64,\" alt=\"6 x minus 2 y, equals 0\"></span></span></p>\n"
