      "content": "<p class=\"choice_paragraph block_choice\"><span class=\"math_expression \"><span class=\"math-container\"><img align=\"middle\" role=\"math\" class=\"math-img\" src=\"data:image/png;base64,\" alt=\"x plus 3 y, equals 5\"></span></span></p>\n"
    },
    {
      "id": "b",
      "content": "<p class=\"choice_paragraph block_choice\"><span class=\"math_expression \"><span class=\"math-container\"><img align=\"middle\" role=\"math\" class=\"math-img\" src=\"data:image/png;base64,\" alt=\"x plus 3 y, equals negative 20\"></span></span></p>\n"
