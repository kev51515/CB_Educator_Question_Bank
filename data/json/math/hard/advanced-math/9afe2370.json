  "type": "mcq",
  "stem": "<p class=\"stem_paragraph \">If during this time the population of the city decreases by a fixed percent each year, which of the following must be true?</p>\n",
  "answerOptions": [
    {
      "id": "a",
      "content": "<span class=\"math_expression \">\n            <span class=\"math-container\"><img align=\"middle\" role=\"math\" class=\"math-img\" src=\"data:image/png;base64,\" alt=\"r is less than negative 1\"></span></span>\n"
    },
    {
      "id": "b",
      "content": "<span class=\"math_expression \">\n            <span class=\"math-container\"><img align=\"middle\" role=\"math\" class=\"math-img\" src=\"data:image/png;base64,\" alt=\"negative 1 is less than r, which is less than 0\"></span></span>\n"
    },
    {
      "id": "c",
      "content": "<span class=\"math_expression \">\n            <span class=\"math-container\"><img align=\"middle\" role=\"math\" class=\"math-img\" src=\"data:image/png;base64,\" alt=\"0 is less than r, which is less than 1\"></span></span>\n"
