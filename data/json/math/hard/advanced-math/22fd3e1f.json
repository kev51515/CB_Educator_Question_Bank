  "type": "mcq",
  "stem": "<p class=\"stem_paragraph \">Which of the following expressions is equivalent to <span class=\"math_expression \"><span class=\"math-container\"><img align=\"middle\" role=\"math\" class=\"math-img\" src=\"data:image/png;base64,\" alt=\"the fraction f of x over g of x\"></span></span>, for <span class=\"math_expression \"><span class=\"math-container\"><img align=\"middle\" role=\"math\" class=\"math-img\" src=\"data:image/png;base64,\" alt=\"x is greater than 3\"></span></span>&nbsp;?</p>\n",
  "answerOptions": [
    {
      "id": "a",
      "content": "<p><span class=\"math_expression \"><span class=\"math-container\"><img align=\"middle\" role=\"math\" class=\"math-img\" src=\"data:image/png;base64,\" alt=\"the fraction with numerator 1, and denominator x plus 1, end fraction\"></span></span></p>\n"
