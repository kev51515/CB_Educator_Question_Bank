    },
    {
      "id": "c",
      "content": "<p><span class=\"math_expression \"><span class=\"math-container\"><img align=\"middle\" role=\"math\" class=\"math-img\" src=\"data:image/png;base64,\" alt=\"the fraction with numerator x times, open parenthesis, x minus 3, close parenthesis, and denominator x plus 1, end fraction\"></span></span></p>\n"
